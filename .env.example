# Live manager / dynamic trailing / adaptive optimizer
LIVE_MANAGER_ENABLED=true
LIVE_MANAGER_AUTO_START=true
LIVE_MANAGER_SLEEP_SECONDS=10
PA_TRAIL_ENABLED=true
PA_TRAIL_BARS=3
PA_TRAIL_INTERVAL=5m
PA_TRAIL_ACTIVATE_R=0.75
ADAPTIVE_ENABLED=true
ADAPTIVE_LOOKBACK_TRADES=20
ADAPTIVE_MIN_TRADES=6
ADAPTIVE_MAX_LOSS_STREAK=3
ADAPTIVE_MIN_WIN_RATE=35
ADAPTIVE_PAUSE_MINUTES=30
# PRO Engine context filter
PRO_ENGINE_ENABLED=true
PRO_REGIME_INTERVAL=15m
PRO_REGIME_LIMIT=80
PRO_BLOCK_CHOP=true
PRO_CHOP_RANGE_MULT=5.0
PRO_ENTRY_BODY_MIN=0.55
PRO_ENTRY_CLOSE_TOP_BOTTOM=0.35
PRO_MAX_TRADES_PER_HOUR=2
PRO_SYMBOL_COOLDOWN_MINUTES=20
PRO_LOSS_STREAK_PAUSE_MINUTES=45
PRO_MIN_24H_QUOTE_VOLUME=100000000
PRO_ALLOWED_SYMBOLS=
PRO_BLOCK_LOW_QUALITY_SYMBOLS=true

# Fast protection + price-action trailing recommended settings
BE_TRIGGER_R=0.50

# PRO engine safety

# Safe testing mode
SCANNER_EXCHANGE=paper
ENABLE_EXECUTION=false
