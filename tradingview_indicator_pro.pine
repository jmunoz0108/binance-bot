//@version=6
indicator("Bot Signal Engine PRO - BOS Sweep Continuation TP", overlay=true, max_labels_count=500, max_lines_count=500)

secretInput = input.string("123456", "Bot Secret")
exchangeInput = input.string("paper", "Exchange", options=["paper", "binance_futures"])
leverageInput = input.int(2, "Leverage", minval=1, maxval=50)

pivotLen = input.int(3, "Pivot Length", minval=1)
volLen = input.int(20, "Volume Length")
volMult = input.float(1.5, "Volume Spike Multiplier", step=0.1)
cooldownBars = input.int(10, "Signal Cooldown Bars", minval=1)

showTP = input.bool(true, "Show TP / SL Lines")
riskPct = input.float(0.7, "Visual Stop %", step=0.1)
tp1R = input.float(1.0, "TP1 R", step=0.25)
tp2R = input.float(2.0, "TP2 R", step=0.25)
tp3R = input.float(3.0, "TP3 R", step=0.25)

continuationEnabled = input.bool(true, "Continuation Mode")
pullbackMin = input.float(0.25, "Pullback Min %", step=0.05)
pullbackMax = input.float(2.50, "Pullback Max %", step=0.05)
contLookback = input.int(8, "Continuation Lookback", minval=3)

ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low, pivotLen, pivotLen)

var float lastHigh = na
var float prevHigh = na
var float lastLow = na
var float prevLow = na

if not na(ph)
    prevHigh := lastHigh
    lastHigh := ph

if not na(pl)
    prevLow := lastLow
    lastLow := pl

hasStructure = not na(lastHigh) and not na(prevHigh) and not na(lastLow) and not na(prevLow)

bull = hasStructure and lastHigh > prevHigh and lastLow > prevLow
bear = hasStructure and lastHigh < prevHigh and lastLow < prevLow

bullBos = hasStructure and close > lastHigh
bearBos = hasStructure and close < lastLow

bullSweep = hasStructure and low < lastLow and close > lastLow
bearSweep = hasStructure and high > lastHigh and close < lastHigh

sweep = bullSweep or bearSweep
sweepDir = bullSweep ? "bullish" : bearSweep ? "bearish" : "none"

volAvg = ta.sma(volume, volLen)
volSpike = volume > volAvg * volMult

bullCandle = close > open
bearCandle = close < open

recentHigh = ta.highest(high[1], contLookback)
recentLow = ta.lowest(low[1], contLookback)

bullPullbackPct = recentHigh > 0 ? ((recentHigh - low) / recentHigh) * 100 : 0.0
bearPullbackPct = recentLow > 0 ? ((high - recentLow) / recentLow) * 100 : 0.0

bullMinorBreak = close > high[1]
bearMinorBreak = close < low[1]

bullContinuation = continuationEnabled and bull and bullMinorBreak and bullPullbackPct >= pullbackMin and bullPullbackPct <= pullbackMax
bearContinuation = continuationEnabled and bear and bearMinorBreak and bearPullbackPct >= pullbackMin and bearPullbackPct <= pullbackMax

rawLong = bull and ((bullBos or bullSweep) or bullContinuation) and volSpike and bullCandle
rawShort = bear and ((bearBos or bearSweep) or bearContinuation) and volSpike and bearCandle

var int lastSignalBar = na
canSignal = na(lastSignalBar) or bar_index - lastSignalBar > cooldownBars

longSignal = rawLong and canSignal and barstate.isconfirmed
shortSignal = rawShort and canSignal and barstate.isconfirmed

if longSignal or shortSignal
    lastSignalBar := bar_index

makeJson(sig, bosVal, candleVal, contVal, contDir, minorBreakVal, pullbackPctVal) =>
    "{\"signal\":\"" + sig + "\",\"ticker\":\"" + syminfo.ticker + "\",\"tf\":\"" + timeframe.period + "\",\"close\":" + str.tostring(close) + ",\"exchange\":\"" + exchangeInput + "\",\"futures_mode\":\"one_way\",\"margin_type\":\"isolated\",\"leverage\":" + str.tostring(leverageInput) + ",\"position_side\":\"BOTH\",\"secret\":\"" + secretInput + "\",\"strategy\":\"TradingView PRO BOS Sweep Continuation\",\"extra\":{\"highs\":[" + str.tostring(high[2]) + "," + str.tostring(high[1]) + "," + str.tostring(high) + "],\"lows\":[" + str.tostring(low[2]) + "," + str.tostring(low[1]) + "," + str.tostring(low) + "],\"bos\":" + str.tostring(bosVal) + ",\"sweep\":" + str.tostring(sweep) + ",\"sweep_direction\":\"" + sweepDir + "\",\"volume_spike\":" + str.tostring(volSpike) + ",\"candle_confirm\":" + str.tostring(candleVal) + ",\"continuation\":" + str.tostring(contVal) + ",\"continuation_direction\":\"" + contDir + "\",\"minor_break\":" + str.tostring(minorBreakVal) + ",\"pullback_pct\":" + str.tostring(pullbackPctVal) + "}}"

if longSignal
    alert(makeJson("long", bullBos, bullCandle, bullContinuation, bullContinuation ? "bullish" : "none", bullMinorBreak, bullPullbackPct), alert.freq_once_per_bar_close)

if shortSignal
    alert(makeJson("short", bearBos, bearCandle, bearContinuation, bearContinuation ? "bearish" : "none", bearMinorBreak, bearPullbackPct), alert.freq_once_per_bar_close)

plotshape(longSignal, title="BOT LONG", location=location.belowbar, color=color.lime, style=shape.labelup, text="LONG")
plotshape(shortSignal, title="BOT SHORT", location=location.abovebar, color=color.red, style=shape.labeldown, text="SHORT")

plotshape(bullContinuation and not longSignal, title="Bull Continuation Setup", location=location.belowbar, color=color.new(color.lime, 45), style=shape.triangleup, text="CONT")
plotshape(bearContinuation and not shortSignal, title="Bear Continuation Setup", location=location.abovebar, color=color.new(color.red, 45), style=shape.triangledown, text="CONT")

plot(lastHigh, "Structure High", color=color.new(color.red, 30))
plot(lastLow, "Structure Low", color=color.new(color.lime, 30))

bgcolor(bull ? color.new(color.green, 92) : bear ? color.new(color.red, 92) : color.new(color.gray, 95))

var line entryLine = na
var line slLine = na
var line tp1Line = na
var line tp2Line = na
var line tp3Line = na
var label tradeLabel = na

newVisualTrade(_isLong) =>
    if not na(entryLine)
        line.delete(entryLine)
        line.delete(slLine)
        line.delete(tp1Line)
        line.delete(tp2Line)
        line.delete(tp3Line)
    if not na(tradeLabel)
        label.delete(tradeLabel)

    entry = close
    risk = entry * riskPct / 100.0
    sl = _isLong ? entry - risk : entry + risk
    tp1 = _isLong ? entry + risk * tp1R : entry - risk * tp1R
    tp2 = _isLong ? entry + risk * tp2R : entry - risk * tp2R
    tp3 = _isLong ? entry + risk * tp3R : entry - risk * tp3R

    entryLine := line.new(bar_index, entry, bar_index + 50, entry, extend=extend.right, color=color.white, width=1)
    slLine := line.new(bar_index, sl, bar_index + 50, sl, extend=extend.right, color=color.red, width=2)
    tp1Line := line.new(bar_index, tp1, bar_index + 50, tp1, extend=extend.right, color=color.yellow, width=1)
    tp2Line := line.new(bar_index, tp2, bar_index + 50, tp2, extend=extend.right, color=color.orange, width=1)
    tp3Line := line.new(bar_index, tp3, bar_index + 50, tp3, extend=extend.right, color=color.lime, width=1)

    tradeLabel := label.new(bar_index, _isLong ? low : high, _isLong ? "BOT LONG\\nTP1/TP2/TP3 shown" : "BOT SHORT\\nTP1/TP2/TP3 shown", style=_isLong ? label.style_label_up : label.style_label_down, color=_isLong ? color.green : color.red, textcolor=color.white)

if showTP and longSignal
    newVisualTrade(true)

if showTP and shortSignal
    newVisualTrade(false)

exitLongVisual = bearSweep or bearBos
exitShortVisual = bullSweep or bullBos

plotshape(exitLongVisual and bull[1], title="Possible Long Exit", location=location.abovebar, color=color.orange, style=shape.xcross, text="EXIT?")
plotshape(exitShortVisual and bear[1], title="Possible Short Exit", location=location.belowbar, color=color.orange, style=shape.xcross, text="EXIT?")
